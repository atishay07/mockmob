{
  "name": "mockmob",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --use-system-ca node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "node --use-system-ca node_modules/next/dist/bin/next start",
    "lint": "eslint",
    "nta:sample": "node --use-system-ca scripts/nta-sample.mjs",
    "nta:diagnose": "node --use-system-ca scripts/nta-diagnose.mjs",
    "test:nta": "node --test data/tests/nta_question_selector.test.mjs",
    "db:seed": "node scripts/seed.mjs",
    "autonomous": "node --use-system-ca --env-file=.env.local scripts/pipeline/autonomous/worker.mjs --start",
    "validate:sample": "node --use-system-ca --env-file=.env.local scripts/pipeline/validate-existing.mjs --mode=sample --sample-size=50",
    "validate:dry-run": "node --use-system-ca --env-file=.env.local scripts/pipeline/validate-existing.mjs --mode=dry-run",
    "validate:apply": "node --use-system-ca --env-file=.env.local scripts/pipeline/validate-existing.mjs --mode=apply"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "openai": "^6.34.0",
    "razorpay": "^2.9.6",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4"
  }
}
